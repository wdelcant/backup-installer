#!/bin/bash
# =============================================================================
# INVITSM Backup Pipeline Script
# Generated by INVITSM Backup Installer v{{.Version}}
# Generated: {{.Generated}}
# =============================================================================
# DO NOT EDIT MANUALLY - Re-run installer to modify
# =============================================================================

set -euo pipefail

# Configuration
CONFIG_FILE="{{.ConfigPath}}"
BACKUP_DIR="{{.BackupDir}}"
LOG_FILE="{{.LogDir}}/pipeline-$(date +%Y-%m-%d).log"
WEBHOOK_URL="{{.WebhookURL}}"
WEBHOOK_ENABLED={{.WebhookEnabled}}

# Source database
SOURCE_HOST="{{.SourceHost}}"
SOURCE_PORT={{.SourcePort}}
SOURCE_DB="{{.SourceDB}}"
SOURCE_USER="{{.SourceUser}}"
SOURCE_PASS="{{.SourcePass}}"

# Target database (optional)
TARGET_ENABLED={{.TargetEnabled}}
TARGET_HOST="{{.TargetHost}}"
TARGET_PORT={{.TargetPort}}
TARGET_DB="{{.TargetDB}}"
TARGET_USER="{{.TargetUser}}"
TARGET_PASS="{{.TargetPass}}"
RESTORE_DELAY={{.RestoreDelay}}

# Retention
RETENTION_DAYS={{.RetentionDays}}

# =============================================================================
# Functions
# =============================================================================

log() {
    local level="$1"
    local message="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $message" | tee -a "$LOG_FILE"
}

send_webhook() {
    local status="$1"
    local payload="$2"
    
    if [ "$WEBHOOK_ENABLED" != "true" ] || [ -z "$WEBHOOK_URL" ]; then
        return 0
    fi
    
    log "INFO" "Enviando webhook a n8n..."
    
    HTTP_CODE=$(curl -s -X POST \
        -H "Content-Type: application/json" \
        -d "$payload" \
        "$WEBHOOK_URL" \
        --max-time 30 \
        -o /dev/null \
        -w "%{http_code}" || echo "000")
    
    if [ "$HTTP_CODE" = "200" ]; then
        log "INFO" "✅ Webhook enviado exitosamente"
    else
        log "WARN" "⚠️  Webhook falló (HTTP $HTTP_CODE)"
    fi
}

cleanup_old_backups() {
    log "INFO" "Limpiando backups antiguos (> $RETENTION_DAYS días)..."
    local deleted=$(find "$BACKUP_DIR" -name "*.sql.gz" -type f -mtime +$RETENTION_DAYS -delete -print | wc -l)
    log "INFO" "✓ Eliminados $deleted backups antiguos"
}

# =============================================================================
# Main Pipeline
# =============================================================================

PIPELINE_START=$(date +%s)
PIPELINE_ID="pipe_$(date +%Y%m%d_%H%M%S)"

log "INFO" "🚀 Iniciando pipeline $PIPELINE_ID"

# === FASE 1: BACKUP ===
log "INFO" "📦 Fase 1: Creando backup de producción..."

BACKUP_START=$(date +%s)
BACKUP_FILE="$BACKUP_DIR/${SOURCE_DB}_backup_$(date +%Y%m%d_%H%M%S).sql.gz"

export PGPASSWORD="$SOURCE_PASS"
pg_dump -h "$SOURCE_HOST" -p "$SOURCE_PORT" -U "$SOURCE_USER" \
    --no-owner --no-privileges "$SOURCE_DB" | gzip > "$BACKUP_FILE"
BACKUP_STATUS=$?
unset PGPASSWORD

BACKUP_END=$(date +%s)
BACKUP_DURATION=$((BACKUP_END - BACKUP_START))

if [ $BACKUP_STATUS -eq 0 ]; then
    BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
    log "INFO" "✅ Backup completado: $BACKUP_FILE ($BACKUP_SIZE)"
else
    log "ERROR" "❌ Backup falló"
    
    # Send error webhook
    PAYLOAD=$(cat <<EOF
{
  "event": "backup.failed",
  "pipeline_id": "$PIPELINE_ID",
  "timestamp": "$(date -Iseconds)",
  "phase": "backup",
  "error": "pg_dump failed with status $BACKUP_STATUS"
}
EOF
)
    send_webhook "failed" "$PAYLOAD"
    exit 1
fi

# === FASE 2: RESTORE (si está habilitado) ===
if [ "$TARGET_ENABLED" = "true" ]; then
    log "INFO" "🔄 Fase 2: Restaurando en QA/Dev..."
    
    # Delay si está configurado
    if [ $RESTORE_DELAY -gt 0 ]; then
        log "INFO" "Esperando $RESTORE_DELAY minutos antes del restore..."
        sleep $((RESTORE_DELAY * 60))
    fi
    
    RESTORE_START=$(date +%s)
    
    # Backup de seguridad de QA
    if [ true ]; then
        SAFETY_BACKUP="$BACKUP_DIR/qa_pre_restore_$(date +%Y%m%d_%H%M%S).sql.gz"
        export PGPASSWORD="$TARGET_PASS"
        pg_dump -h "$TARGET_HOST" -p "$TARGET_PORT" -U "$TARGET_USER" \
            --no-owner --no-privileges "$TARGET_DB" | gzip > "$SAFETY_BACKUP" 2>/dev/null || true
        unset PGPASSWORD
        log "INFO" "💾 Safety backup creado: $SAFETY_BACKUP"
    fi
    
    # Restore
    export PGPASSWORD="$TARGET_PASS"
    gunzip -c "$BACKUP_FILE" | psql -h "$TARGET_HOST" -p "$TARGET_PORT" -U "$TARGET_USER" -d "$TARGET_DB" >> "$LOG_FILE" 2>&1
    RESTORE_STATUS=$?
    unset PGPASSWORD
    
    RESTORE_END=$(date +%s)
    RESTORE_DURATION=$((RESTORE_END - RESTORE_START))
    
    if [ $RESTORE_STATUS -eq 0 ]; then
        log "INFO" "✅ Restore completado en ${RESTORE_DURATION}s"
    else
        log "ERROR" "❌ Restore falló"
        
        PAYLOAD=$(cat <<EOF
{
  "event": "restore.failed",
  "pipeline_id": "$PIPELINE_ID",
  "timestamp": "$(date -Iseconds)",
  "phase": "restore",
  "error": "psql failed with status $RESTORE_STATUS"
}
EOF
)
        send_webhook "failed" "$PAYLOAD"
        exit 1
    fi
fi

# === FASE 3: Limpieza ===
cleanup_old_backups

# === FASE 4: Webhook de éxito ===
PIPELINE_END=$(date +%s)
PIPELINE_DURATION=$((PIPELINE_END - PIPELINE_START))

PAYLOAD=$(cat <<EOF
{
  "event": "backup.pipeline.completed",
  "pipeline_id": "$PIPELINE_ID",
  "timestamp": "$(date -Iseconds)",
  "pipeline": {
    "status": "success",
    "duration_seconds": $PIPELINE_DURATION
  },
  "backup": {
    "status": "success",
    "duration_seconds": $BACKUP_DURATION,
    "file": {
      "path": "$BACKUP_FILE",
      "size_human": "$BACKUP_SIZE"
    }
  },
  "restore": {
    "status": "$( [ "$TARGET_ENABLED" = "true" ] && echo "success" || echo "skipped" )",
    "duration_seconds": ${RESTORE_DURATION:-0}
  }
}
EOF
)

send_webhook "success" "$PAYLOAD"

log "INFO" "🎉 Pipeline completado exitosamente en ${PIPELINE_DURATION}s"